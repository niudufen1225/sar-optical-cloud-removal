# SoftShadow(SAM-LoRA) + DADIGAN restoration baseline for ALLClear.
# 任务：
#   输入：cloudy s2_toa 13 通道 + s1 2 通道 + SoftShadow 离线 division mask/bbox prompt。
#   输出：13 通道 cloud/shadow-free S2。
#
# 数据流：
#   1. SoftShadow 官方路径：RGB(S2 bands [3,2,1]) -> Resize(1024) -> ImageNet normalize
#      -> SAM ViT-H image encoder + bbox prompt -> mask decoder -> sigmoid -> M_shadow_soft。
#      shadow_case 会跳过 no_shadow/ambiguous 的 SoftShadow 监督，并把这些样本的 M_shadow_soft 置零。
#   2. 复用 SoftShadow 的 soft mask loss：
#      L_mask = MSE(M_shadow_soft, division_mask)，其中 division_mask 由 target/cloudy Y 通道亮度比构造。
#      L_pen  = 官方 contour_gradient_noPenumbra_penalty_loss，权重 0.1。
#   3. DaDiGAN restoration backbone：
#      M_restore = M_cloud_hard OR M_shadow_soft。
#      masked_s2 = (1-M_restore)*S2 + M_restore*learned_token，并额外拼接 M_restore。
#      DaDiGAN 输入 masked_s2 + SAR，输出 13 通道 raw fill，再 composite 成最终图。
#   4. restoration loss：
#      SoftShadow 的 L_rem 仍保留为全图 restoration loss；当前配置用 MSE(I_hat, target)，权重 1；
#      额外给 DaDiGAN backbone 一个较小的 mask 区 L1/KL 和延迟开启的 cGAN。
#
# 重要限制：
#   SoftShadow 官方去阴影 backbone 是 ShadowDiffusion，但论文说明 backbone 可替换。
#   这里只严格复现 SoftShadow 的 SAM-LoRA mask 分支与三项 loss 组合；
#   restoration backbone 替换为 DaDiGAN，因此不是官方 SoftShadow+ShadowDiffusion 的完全复刻。
run_name: allclear_softshadow_dadigan_baseline
output_root: outputs/allclear
seed: 2026

data:
  root: /home/students/sushaoqi/CR/allclear_10pct_tx3_s2_s1_bucketed
  cache_dir: /home/students/sushaoqi/CR/allclear_10pct_tx3_s2_s1_bucketed/cache/unused300_image256_sar
  train_manifest: /home/students/sushaoqi/CR/allclear_10pct_tx3_s2_s1_bucketed/manifests_official_mask_dadigan_damage/pairs_train.csv
  val_manifest: /home/students/sushaoqi/CR/allclear_10pct_tx3_s2_s1_bucketed/manifests_official_mask_dadigan_damage/pairs_val.csv
  test_manifest: /home/students/sushaoqi/CR/allclear_10pct_tx3_s2_s1_bucketed/manifests_official_mask_dadigan_damage/pairs_test.csv
  optical_scale: 10000.0
  load_sar: true
  image_size: 256
  rgb_indices: [3, 2, 1]
  shadow_index: 3
  cloud_index: 1
  # SoftShadow 官方严格路径：离线 division_filter_results 和 bbox YAML。
  # 本配置必须使用 split-specific prompt；这些文件由 paired cloudy/clear
  # Y-channel division target 生成，不用 ALLClear hard shadow support 裁剪 soft target。
  softshadow_mask_dir:
  softshadow_bbox_path:
  softshadow_mask_dir_train: /home/students/sushaoqi/CR/allclear_10pct_tx3_s2_s1_bucketed/softshadow_prompts/train/division_filter_results
  softshadow_mask_dir_val: /home/students/sushaoqi/CR/allclear_10pct_tx3_s2_s1_bucketed/softshadow_prompts/val/division_filter_results
  softshadow_mask_dir_test: /home/students/sushaoqi/CR/allclear_10pct_tx3_s2_s1_bucketed/softshadow_prompts/test/division_filter_results
  softshadow_bbox_path_train: /home/students/sushaoqi/CR/allclear_10pct_tx3_s2_s1_bucketed/softshadow_prompts/train/bounding_boxes.yaml
  softshadow_bbox_path_val: /home/students/sushaoqi/CR/allclear_10pct_tx3_s2_s1_bucketed/softshadow_prompts/val/bounding_boxes.yaml
  softshadow_bbox_path_test: /home/students/sushaoqi/CR/allclear_10pct_tx3_s2_s1_bucketed/softshadow_prompts/test/bounding_boxes.yaml
  # SoftShadow shadow_case 三状态；baseline 中 no_shadow/ambiguous 不进入 soft shadow restore mask。
  softshadow_shadow_case_enabled: true
  softshadow_shadow_case_positive_threshold: 0.05
  softshadow_absent_shadow_threshold: 0.002
  softshadow_absent_division_threshold: 0.002
  softshadow_valid_shadow_threshold: 0.002
  softshadow_valid_division_threshold: 0.005
  softshadow_max_bbox_area: 0.80
  softshadow_min_division_shadow_precision_dilated: 0.30
  softshadow_max_clear_leakage: 0.30
  softshadow_max_cloud_leakage: 0.30

model:
  framework: softshadow_dadigan_baseline
  s2_channels: 13
  sar_channels: 2
  dim: 64

  # SoftShadow 官方 SAM-LoRA 设置：ViT-H、rank=8、1024 输入、bbox prompt。
  softshadow_repo: /home/students/sushaoqi/CR/main/external/SoftShadow
  sam_checkpoint: /home/students/sushaoqi/CR/main/pretrained/sam_vit_h_4b8939.pth
  softshadow_checkpoint:
  softshadow_sam_model_type: vit_h
  softshadow_sam_lora_rank: 8
  softshadow_sam_input_size: 1024
  # 官方 bbox YAML 对应 Resize(1024) 后的 SAM 输入坐标；若 bbox 是 256 图像坐标，改成 image。
  softshadow_bbox_space: sam_input
  # 严格 SoftShadow：SAM-LoRA soft mask 不再乘 ALLClear hard-shadow gate。
  softshadow_use_hard_support_gate: false
  softshadow_forward_valid_only: true
  # ViT-H 1024 反传显存很高；checkpointing 不改变计算图语义，只重算中间 activation。
  softshadow_sam_checkpoint_blocks: true

  # cloud_plus_soft_shadow：用 hard cloud mask 和 SAM soft shadow mask 共同定义待恢复区域。
  # DaDiGAN 只看到一个 restoration mask，不区分云/阴影语义。
  restore_mask_mode: cloud_plus_soft_shadow

  # DaDiGAN backbone。CAB 使用 SRA-CAB，MSAB 使用 Restormer MDTA 消融版本。
  cloud_ddin_steps: 3
  cloud_prox_blocks: 5
  cloud_reconstruct_blocks: 2
  cloud_cab_sr_ratio: 8
  cloud_cab_attention_mode: complement
  cloud_msab_mode: restormer_mdta

  # Mask-conditioned inpainting 输入：避免让 DaDiGAN 直接复制云/阴影纹理。
  cloud_mask_input_mode: learned
  cloud_append_mask: true
  cloud_mask_fill_value: 0.0

  # cGAN 判别器看最终 composite，并以 M_restore 为条件。
  cloud_discriminator_condition_mask: true
  cloud_discriminator_base_channels: 32
  cloud_discriminator_layers: 5
  cloud_discriminator_norm: batch
  cloud_discriminator_output: patch

loss:
  final_mask_mode: all
  final_l1: 0.0
  grad: 0.0

  # SoftShadow 官方联合训练权重：L_mask + 0.1*L_pen + 1*L_rem。
  shadow_mask: 1.0
  shadow_mask_region: all
  shadow_mask_outside_weight: 1.0
  shadow_penumbra: 0.1
  shadow_penumbra_mode: softshadow_no_penumbra
  shadow_removal: 1.0
  shadow_removal_region: all
  # 论文公式写作 Frobenius/L2；若需要 DaDiGAN-style L1 消融，可改为 l1。
  shadow_removal_loss_type: mse
  shadow_soft_target_low_pass_kernel: 3
  shadow_soft_target_mode: offline_required
  shadow_soft_target_division_threshold: 0.05
  shadow_case_gating: true

  # DaDiGAN restoration backbone 的辅助约束。
  # M_cloud 在该 framework 中等价于 M_restore，所以 cloud_l1_region=cloud 表示只约束恢复区。
  # 这里不使用 DADIGAN 原文 100/100/1 的比例，因为 SoftShadow 的 Lrem 已经是主恢复损失；
  # 这些项只用来约束 13 通道光谱一致性和恢复区真实感，避免压制 SAM soft mask 学习。
  cloud_l1: 1.0
  cloud_l1_region: cloud
  cloud_l1_reduction: mask_mean
  cloud_kl: 0.2
  cloud_kl_mode: softplus_sum
  cloud_kl_reduction: mask_mean
  cloud_adv: 0.02
  adversarial_loss: bce
  cloud_gan_image: composite

loss_schedule:
  shadow_mask: {start_epoch: 1, ramp_epochs: 0}
  shadow_penumbra: {start_epoch: 1, ramp_epochs: 0}
  shadow_removal: {start_epoch: 1, ramp_epochs: 0}
  cloud_l1: {start_epoch: 1, ramp_epochs: 0}
  cloud_kl: {start_epoch: 1, ramp_epochs: 0}
  cloud_adv: {start_epoch: 10, ramp_epochs: 10}

train:
  epochs: 100
  batch_size: 1
  grad_accum_steps: 8
  val_batch_size: 1
  num_workers: 6
  pin_memory: true
  persistent_workers: true
  prefetch_factor: 2
  optimizer: adam
  # SoftShadow 官方 joint config 使用 1e-5；这里优先保护 SAM-LoRA 稳定性。
  lr: 1.0e-5
  disc_lr: 4.0e-5
  weight_decay: 0.0
  distributed: ddp
  dist_backend: nccl
  ddp_find_unused_parameters: false
  optimizer_fused: false
  optimizer_foreach: false
  allow_tf32: true
  matmul_precision: high
  cudnn_benchmark: true
  torch_compile: false
  amp: true
  amp_dtype: bf16
  grad_clip_norm: 1.0
  lr_scheduler: none
  val_every: 1
  best_metric: recon_total
  keep_best: 1

eval:
  batch_size: 1
  num_workers: 6
  pin_memory: true
  persistent_workers: true
  prefetch_factor: 2
  visualize_splits: [val, test]
  visualization_checkpoint: best
  visual_samples_per_bucket: 3
