\# ============================================================
# Python 缓存与构建文件
# ============================================================
__pycache__/
*.py[cod]
*$py.class
*.so

build/
dist/
*.egg-info/
.eggs/

.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/


# ============================================================
# Python / Conda 虚拟环境
# 不要把整个环境上传到 GitHub
# ============================================================
.venv/
venv/
env/
ENV/
conda-env/


# ============================================================
# 编辑器和系统临时文件
# ============================================================
.vscode/
.idea/
*.code-workspace

*.swp
*.swo
*.swn
*~
.DS_Store
Thumbs.db


# ============================================================
# 本地 AI 编程工具配置
# 保留可共享的 CLAUDE.md、commands 等规则，
# 只忽略本机配置、缓存和日志
# ============================================================
.claude/settings.local.json
.claude/cache/
.claude/logs/
.claude/history/

.codex/
.cursor/


# ============================================================
# 密钥和本地环境变量
# ============================================================
.env
.env.*
!.env.example

*.pem
*.key
*.p12
*.pfx

credentials.json
credentials*.json
secrets.yaml
secrets.yml
secrets.json


# ============================================================
# 数据集
# 数据应放在 Git 仓库外部
# ============================================================
data/
dataset/
datasets/
data-weight/

SEN12MSCR/
ROIs1158_spring_s1/
ROIs1158_spring_s2/
ROIs1158_spring_s2_cloudy/


# ============================================================
# 训练输出、日志和实验缓存
# ============================================================
outputs/
output/
results/
runs/
logs/
log/

wandb/
tensorboard/
lightning_logs/

cache/
tmp/
temp/


# ============================================================
# 模型权重和导出模型
# ============================================================
pretrained/
checkpoints/
checkpoint/
weights/

*.pth
*.pt
*.ckpt
*.safetensors
*.onnx
*.engine
*.trt


# ============================================================
# 遥感影像和大型数组
# 防止误传原始数据和中间结果
# ============================================================
*.tif
*.tiff
*.vrt
*.img

*.h5
*.hdf5
*.npy
*.npz
*.zarr
*.mat


# ============================================================
# 本地论文原文
# 根目录下的论文 PDF 不上传
# 建议将有价值的总结整理到 docs/*.md
# ============================================================
/*.pdf
/local_papers/
/papers/
/references/


# ============================================================
# 临时备份
# ============================================================
*.bak
*.tmp
*.temp

# Third-party repositories managed separately
/external/SoftShadow/
/external/TG-ECNet/
/external/efficientvit/

# ============================================================
# 保留 allclear 实验中的轻量日志、配置和评估指标
# ============================================================
!outputs/
outputs/*

!outputs/allclear/
outputs/allclear/**

# 允许 Git 继续遍历各级实验目录
!outputs/allclear/**/

# 只上传轻量文本日志和配置
!outputs/allclear/**/*.log
!outputs/allclear/**/*.txt
!outputs/allclear/**/*.json
!outputs/allclear/**/*.jsonl
!outputs/allclear/**/*.yaml
!outputs/allclear/**/*.yml
!outputs/allclear/**/*.csv
!outputs/allclear/**/*.md

# TensorBoard 日志；不需要时删除下一行
!outputs/allclear/**/events.out.tfevents.*
